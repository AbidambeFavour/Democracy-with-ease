{
	"info": {
		"_postman_id": "simplevote-api-collection",
		"name": "SimpleVote API Collection",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
		"_exporter_id": "simplevote-export"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "User Registration",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "testuser123"
								},
								{
									"key": "email",
									"value": "testuser123@example.com"
								},
								{
									"key": "first_name",
									"value": "Test"
								},
								{
									"key": "last_name",
									"value": "User"
								},
								{
									"key": "password1",
									"value": "complexpassword123"
								},
								{
									"key": "password2",
									"value": "complexpassword123"
								}
							]
						},
						"url": "http://127.0.0.1:8000/accounts/register/"
					}
				}
			]
		},
		{
			"name": "Poll Management",
			"item": [
				{
					"name": "List All Polls",
					"request": {
						"method": "GET",
						"header": [],
						"body": {},
						"url": "http://127.0.0.1:8000/voting/"
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000",
			"description": "Base URL for the SimpleVote application"
		}
	]
}
