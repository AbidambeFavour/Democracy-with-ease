            "url": {
              "raw": "{{baseUrl}}/accounts/register/",
              "host": ["{{baseUrl}}"],
              "path": ["accounts", "register", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Registration successful\", function() {",
