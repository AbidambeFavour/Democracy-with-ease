                },
                {
                  "key": "email",
                  "value": "test{{$randomInt}}@example.com",
                  "type": "text"
                },
                {
                  "key": "password1",
                  "value": "SecurePass123",
                  "type": "text"
                },
                {
                  "key": "password2",
                  "value": "SecurePass123",
                  "type": "text"
                },
                {
                  "key": "first_name",
                  "value": "Test",
                  "type": "text"
                },
                {
                  "key": "last_name",
                  "value": "User",
                  "type": "text"
                }
              ]
